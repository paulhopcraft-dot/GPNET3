# Preventli Railway Environment Variables Template
# Copy these to Railway dashboard → Environment Variables

# ===========================
# Database
# ===========================
# PostgreSQL connection string from Neon
# Format: postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:pass@host.neon.tech/preventli?sslmode=require

# ===========================
# Security & Auth
# ===========================
# Application environment (production|staging|development)
NODE_ENV=production

# JWT secret for token signing (generate: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here-32-chars-minimum

# Session secret for cookie signing (generate: openssl rand -base64 32)
SESSION_SECRET=your-session-secret-here-32-chars-minimum

# ===========================
# Server Configuration
# ===========================
# Port for the server (Railway auto-assigns, default: 10000)
PORT=10000

# Frontend URL for CORS (your Vercel deployment URL)
FRONTEND_URL=https://gpnet3.vercel.app

# ===========================
# AI / LLM Provider
# ===========================
# LLM provider to use (openrouter|anthropic|openai)
LLM_PROVIDER=openrouter

# OpenRouter API key (get from https://openrouter.ai)
# Used when LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic API key (if using direct Anthropic integration)
# Used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (if using OpenAI directly)
# Used when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# ===========================
# Storage Provider (Cloudflare R2 or S3)
# ===========================
# Storage provider (s3|local)
STORAGE_PROVIDER=s3

# S3/R2 bucket name
S3_BUCKET=preventli-uploads

# S3 region (use 'auto' for Cloudflare R2)
S3_REGION=auto

# Cloudflare R2 endpoint
# Format: https://<account-id>.r2.cloudflarestorage.com
# Leave blank for AWS S3 (uses default endpoints)
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# R2/S3 Access Key ID
S3_ACCESS_KEY=your-r2-access-key-id

# R2/S3 Secret Access Key
S3_SECRET_KEY=your-r2-secret-access-key

# Public URL for uploaded files (optional, for direct access)
# For R2: https://your-bucket.r2.dev (after enabling public access)
# Leave blank if files are served via backend proxy
S3_PUBLIC_URL=

# ===========================
# Email Provider (Resend)
# ===========================
# Email provider (resend|smtp|sendgrid|ses)
EMAIL_PROVIDER=resend

# Resend API key (get from https://resend.com)
RESEND_API_KEY=re_...

# Email 'from' address (must be verified domain in Resend)
EMAIL_FROM=noreply@preventli.au

# SMTP settings (if using EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_...

# SendGrid API key (if using EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=SG....

# AWS SES region (if using EMAIL_PROVIDER=ses)
AWS_SES_REGION=us-east-1

# ===========================
# Monitoring & Observability
# ===========================
# Sentry DSN for error tracking (get from https://sentry.io)
# Leave blank to disable Sentry
SENTRY_DSN=https://...@sentry.io/...

# Log level (error|warn|info|debug)
LOG_LEVEL=info

# Enable request logging (true|false)
LOG_REQUESTS=true

# ===========================
# Feature Flags (Optional)
# ===========================
# Enable AI features (true|false)
ENABLE_AI_FEATURES=true

# Enable file uploads (true|false)
ENABLE_FILE_UPLOADS=true

# Enable email notifications (true|false)
ENABLE_EMAIL_NOTIFICATIONS=true

# Max upload size in MB
MAX_UPLOAD_SIZE_MB=10

# ===========================
# Rate Limiting (Optional)
# ===========================
# Enable rate limiting (true|false)
ENABLE_RATE_LIMITING=true

# Max requests per window
RATE_LIMIT_MAX=100

# Rate limit window in minutes
RATE_LIMIT_WINDOW_MIN=15

# ===========================
# Compliance & Legal (Optional)
# ===========================
# Terms of Service URL
TERMS_URL=https://preventli.au/terms

# Privacy Policy URL
PRIVACY_URL=https://preventli.au/privacy

# ===========================
# Admin Configuration (Optional)
# ===========================
# Admin email for system notifications
ADMIN_EMAIL=admin@preventli.au

# Support email for user inquiries
SUPPORT_EMAIL=support@preventli.au

# ===========================
# Notes
# ===========================
# How to generate secrets:
#
# macOS/Linux:
#   openssl rand -base64 32
#
# Windows (PowerShell):
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
#
# Railway Tips:
#   - Variables are injected at runtime (no need to rebuild)
#   - Use Railway's "Add Variable" UI (easier than raw JSON)
#   - Group related variables with comments (Railway preserves formatting)
#   - Sensitive values are encrypted at rest
#   - Use Railway secrets for extra security (DATABASE_URL auto-encrypts)
