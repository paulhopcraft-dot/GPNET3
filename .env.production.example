# Preventli — Production Environment Template
# ============================================================================
# Copy to .env on your production host and fill in ALL values.
# This file must NEVER be committed with real credentials.
#
# Generate secrets:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Validate before deploying:
#   ./scripts/validate-env.sh --env-file .env
# ============================================================================

# ── Application ──────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=5000

# Public-facing HTTPS URLs — MUST use https:// in production
CLIENT_URL=https://app.preventli.ai
APP_URL=https://app.preventli.ai
API_URL=https://app.preventli.ai

# ── Database ─────────────────────────────────────────────────────────────────
# Use a managed PostgreSQL service (Neon, RDS, Supabase) in production.
# Managed services provide automatic backups, HA, and TLS.

DATABASE_URL=postgresql://postgres:CHANGE_ME@db:5432/preventli

# Enable TLS for managed databases (Neon, RDS, Supabase)
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Connection pool — tune for your server's resources
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECT_TIMEOUT=5000

# ── Authentication ────────────────────────────────────────────────────────────
# CRITICAL: Must be at least 32 chars. Use different values for each secret.
# Rotation requires a coordinated deploy — all sessions invalidated on change.

JWT_SECRET=CHANGE_ME_MIN_32_CHARS_UNIQUE_jwt
SESSION_SECRET=CHANGE_ME_MIN_32_CHARS_UNIQUE_session

# ── AI Provider ───────────────────────────────────────────────────────────────
# Production recommendation: openrouter (cost control, fallback models)

LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME

# Optional: pin a specific model version for production stability
# LLM_MODEL=anthropic/claude-sonnet-4-5

# ── Storage ───────────────────────────────────────────────────────────────────
# Production MUST use s3 — local storage is lost on container restart.
# Recommended: Cloudflare R2 (no egress fees) or AWS S3.

STORAGE_PROVIDER=s3

# AWS S3
AWS_S3_BUCKET=preventli-production-uploads
AWS_S3_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# Cloudflare R2 (uncomment and replace AWS settings above)
# AWS_S3_BUCKET=preventli-production-uploads
# AWS_S3_REGION=auto
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME
# AWS_S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# AWS_S3_PUBLIC_URL=https://uploads.preventli.ai

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Required for invites, notifications, certificate expiry alerts.
# Recommended providers: Resend, Postmark, AWS SES

SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_CHANGE_ME
SMTP_SECURE=false
SMTP_FROM=noreply@preventli.ai

# ── Monitoring ────────────────────────────────────────────────────────────────
# Sentry: create a dedicated PRODUCTION project (separate from staging)

SENTRY_DSN=https://CHANGE_ME@o0.ingest.sentry.io/0
SENTRY_TRACES_SAMPLE_RATE=0.1

# Client-side Sentry DSN (embedded in Vite bundle at build time)
# Create a separate Browser project in Sentry for cleaner source-map uploads
VITE_SENTRY_DSN=https://CHANGE_ME@o0.ingest.sentry.io/0

# Client API URL — must match the production app URL with no trailing slash
VITE_API_URL=https://app.preventli.ai

LOG_LEVEL=info

# ── Alerting ─────────────────────────────────────────────────────────────────
# At least one alert channel strongly recommended for production ops.

# Slack incoming webhook (recommended)
ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/CHANGE_ME

# Telegram bot webhook (alternative)
# ALERT_TELEGRAM_WEBHOOK=https://api.telegram.org/bot<TOKEN>/sendMessage?chat_id=<CHAT_ID>

# ── Webhooks ──────────────────────────────────────────────────────────────────

INBOUND_EMAIL_WEBHOOK_SECRET=CHANGE_ME_MIN_32_CHARS

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Enable after verifying the underlying integrations work correctly.

ENABLE_NOTIFICATIONS=true
DAILY_SYNC_ENABLED=true
DAILY_SYNC_TIME=18:00
COMPLIANCE_CHECK_ENABLED=true
COMPLIANCE_CHECK_TIME=06:00
AGENTS_ENABLED=true
AGENT_COORDINATOR_TIME=09:00
AGENT_CERT_EXPIRY_TIME=08:00

# ── Integrations ──────────────────────────────────────────────────────────────

FRESHDESK_DOMAIN=your-subdomain
FRESHDESK_API_KEY=CHANGE_ME
